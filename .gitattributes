# Keep the Composer dist lean — dev-only material isn't shipped to consumers.
# (Affects `composer require` dist archives; full git clones still get everything.)
/.github                export-ignore
/tests                  export-ignore
/examples               export-ignore
/docs                   export-ignore
/tools                  export-ignore
/build-libui.sh         export-ignore
/phpunit.xml            export-ignore
/phpstan.neon           export-ignore
/phpstan-baseline.neon  export-ignore
/mago.toml              export-ignore
/mago-baseline.json     export-ignore
/.junie                 export-ignore
/IMPLEMENTATION_IMPROVEMENTS.md export-ignore
/.gitattributes         export-ignore
/.gitignore             export-ignore
/.editorconfig          export-ignore
/composer.lock          export-ignore

# Prebuilt native libraries are binary; never munge line endings or diff them.
lib/**  binary
*.dylib binary
*.so    binary
*.dll   binary
