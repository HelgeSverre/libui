---
import { Code } from 'astro:components';
import Layout from '../layouts/Layout.astro';

const codeTheme = 'github-light';

const greeter = `<?php

require 'vendor/autoload.php';

use Libui\\Ffi;
use Libui\\Window;
use Libui\\Box;
use Libui\\Entry;
use Libui\\Button;

Ffi::init();

$entry  = new Entry();
$button = (new Button('Greet'))
    ->onClicked(fn () => print("Hi, {$entry->text()}!\\n"));

(new Window('Greeter'))
    ->setChild(
        (new Box(padded: true))
            ->append($entry)
            ->append($button),
    )
    ->run();`;

const tableCode = `// A data grid — no model class, no manual cleanup.
$table = Table::fromRows([
    ['Rasmus Lerdorf',     'PHP',    '1995'],
    ['Yukihiro Matsumoto', 'Ruby',   '1995'],
    ['Guido van Rossum',   'Python', '1991'],
], headers: ['Author', 'Language', 'Year']);`;

const drawCode = `// Custom 2D drawing into a native Area.
$ctx->fillPath(
    Brush::linearGradient(0, 0, 0, $h, [
        Stop::at(0.0, Color::rgb(0x312B90)),
        Stop::at(1.0, Color::rgb(0x0296C3)),
    ]),
    fn (Path $p) => $p->roundedRect(0, 0, $w, $h, 16),
);`;

const shots = [
  { f: 'flowfield.png',  cap: 'Generative art',  sub: 'flowfield.php' },
  { f: 'markdown.png',   cap: 'Markdown editor',  sub: 'markdown.php' },
  { f: 'monitor.png',    cap: 'System monitor',   sub: 'monitor.php' },
  { f: 'colorpicker.png',cap: 'Colour picker',    sub: 'colorpicker.php' },
  { f: 'palette.png',    cap: 'Command palette',  sub: 'palette.php' },
  { f: 'gallery.png',    cap: 'Widget gallery',   sub: 'gallery.php' },
];

const features = [
  ['Typed widgets', 'Windows, boxes, grids, tabs, forms, entries, sliders, spinboxes, combos, date & colour pickers, menus — generated 1:1 from libui\'s C header.'],
  ['Custom 2D drawing', 'Vector <code>Path</code>s with circle/arc/rounded-rect sugar, gradient brushes with typed <code>Stop</code>s, a fluent <code>StrokeParams</code> builder, clipping and transforms.'],
  ['One Color type', '<code>Color::rgb(0x312B90)</code>, <code>::hex()</code>, <code>::rgba()</code>, named — accepted across brushes, text and colour buttons.'],
  ['Data grids', '<code>Table::fromRows()</code> for static data: no delegate class, automatic model lifetime, typed columns, row-index callbacks.'],
  ['Form binding', 'Input widgets implement <code>HasValue</code>; <code>Form::values()</code> / <code>setValues()</code> read and write a whole form at once, keyed by label.'],
  ['Async over the loop', 'The <code>Loop</code> class (<code>defer</code> / <code>delay</code> / <code>repeat</code>) drives HTTP, timers and animation without freezing the UI.'],
];
---

<Layout>
  <nav class="nav">
    <div class="wrap-wide inner">
      <a class="brand" href="/">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="4" width="18" height="16" rx="2.5" stroke="#0b0b0b" stroke-width="2"/><path d="M3 9 H21" stroke="#0b0b0b" stroke-width="2"/></svg>
        libui<span class="v">/php</span>
      </a>
      <div class="links">
        <a href="#build" class="hide-sm">What you build</a>
        <a href="#features" class="hide-sm">Features</a>
        <a href="https://github.com/HelgeSverre/libui/blob/main/docs/GUIDE.md">Docs</a>
        <a href="https://github.com/HelgeSverre/libui">GitHub</a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <header class="hero">
    <div class="wrap-wide">
      <p class="kicker">PHP 8.5 · FFI · libui-ng</p>
      <h1>Native desktop GUIs in PHP.</h1>
      <p class="tagline">Real native windows, widgets, 2D drawing and text — through PHP's
        built-in FFI. No Electron, no web view, no compiled extension.</p>
      <p class="sub">A typed, object-oriented binding to libui-ng. Prebuilt for macOS, Linux and
        Windows; install it and you're drawing pixels.</p>

      <div class="cmd">
        <span class="sigil">$</span> composer require helgesverre/libui
      </div>

      <div class="actions">
        <a class="primary" href="#build">See what you can build</a>
        <a href="https://github.com/HelgeSverre/libui/blob/main/docs/GUIDE.md">Read the guide</a>
        <a href="https://github.com/HelgeSverre/libui">Star on GitHub</a>
      </div>
    </div>
  </header>

  <div class="stars">* &nbsp; * &nbsp; *</div>

  <!-- THE CODE -->
  <section class="section" style="padding-top:52px;">
    <div class="wrap-wide">
      <p class="label">A whole window, in one file</p>
      <div class="codeframe">
        <div class="bar">greeter.php</div>
        <Code code={greeter} lang="php" theme={codeTheme} />
      </div>
      <p class="muted small" style="margin-top:14px; font-family:var(--mono);">
        <code>Window::run()</code> shows the window, runs the event loop, and tears it all down on close.
        One window is one call.
      </p>
    </div>
  </section>

  <!-- WHAT YOU BUILD -->
  <section class="section" id="build" style="padding-top:24px;">
    <div class="wrap-wide">
      <h2>Not toy demos.</h2>
      <p class="lead">Generative art, live dashboards, editors, custom-drawn controls. Every one of
        these is a PHP script in <a href="https://github.com/HelgeSverre/libui/tree/main/examples">examples/</a>.</p>
      <div class="gallery" style="margin-top:34px;">
        {shots.map((s) => (
          <figure class="shot" style="margin:0;">
            <div class="frame"><img src={`/shots/${s.f}`} alt={s.cap} loading="lazy" /></div>
            <figcaption class="cap"><b>{s.cap}</b><span>{s.sub}</span></figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- TWO MORE TASTES -->
  <section class="section" style="padding-top:0;">
    <div class="wrap-wide two">
      <div class="codeframe"><div class="bar">table.php</div><Code code={tableCode} lang="php" theme={codeTheme} /></div>
      <div class="codeframe"><div class="bar">draw.php</div><Code code={drawCode} lang="php" theme={codeTheme} /></div>
    </div>
  </section>

  <div class="wrap-wide"><hr class="rule" /></div>

  <!-- FEATURES -->
  <section class="section" id="features">
    <div class="wrap-wide">
      <h2>Typed all the way down.</h2>
      <p class="lead">Every widget is a class with fluent setters and IDE autocompletion. Anything
        without a sugar wrapper is still reachable raw through the FFI handle.</p>
      <div class="feat" style="margin-top:32px;">
        {features.map(([h, p]) => (
          <div class="row">
            <h3>{h}</h3>
            <p set:html={p}></p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PLATFORMS -->
  <section class="section" style="padding-top:0;">
    <div class="wrap-wide">
      <p class="label">Prebuilt — no compiler</p>
      <div class="plat">
        <div><h3>macOS</h3><p>Universal <code>arm64 + x86_64</code> dylib ships in the package. Works out of the box.</p></div>
        <div><h3>Linux</h3><p>Prebuilt <code>.so</code> for <code>x86_64 + aarch64</code>. Needs GTK 3 installed at runtime.</p></div>
        <div><h3>Windows</h3><p>Prebuilt <code>libui.dll</code> (built with MSVC). No toolchain required.</p></div>
      </div>
    </div>
  </section>

  <div class="wrap-wide"><hr class="rule" /></div>

  <!-- WHY FFI -->
  <section class="section">
    <div class="wrap">
      <p class="label">Why FFI, not a PECL extension</p>
      <h2 style="font-size:clamp(22px,2.6vw,28px);">No C toolchain on your machine.</h2>
      <p class="lead" style="font-size:16px; max-width:64ch;">PHP's old <code>ext-ui</code> is abandoned
        and PHP&nbsp;7-only — it won't compile on modern PHP. This reaches the same goal a different way:
        it loads the maintained <code>libui-ng</code> shared library at runtime and calls it through FFI.
        Nothing to compile, nothing to install but the package — on the PHP you already run.</p>
    </div>
  </section>

  <footer class="foot">
    <div class="wrap-wide inner">
      <span>libui for PHP — MIT</span>
      <span>·</span>
      <a href="https://github.com/HelgeSverre/libui">github.com/HelgeSverre/libui</a>
      <span style="margin-left:auto;">Bundles libui-ng (MIT).</span>
    </div>
  </footer>
</Layout>
