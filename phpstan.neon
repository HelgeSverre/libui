includes:
    - phpstan-baseline.neon

parameters:
    level: 6
    typeAliases:
        DocData: 'array{summary: string, params: array<string, string>, return: string, notes: list<string>, warnings: list<string>}'
        ParsedParam: 'array{raw: string, isCallback: bool, type: string, name: string}'
        ParsedFunction: 'array{name: string, ret: string, params: list<ParsedParam>}'
        Classification: 'array{kind: string, name?: string, scalarOut?: bool}'
        ConstructorConfig: 'array{primary?: string|null, factories?: array<string, string>}'
        GeneratorAnnotations: 'array{skip_types: list<string>, constructors: array<string, ConstructorConfig>, bool_funcs: list<string>, flag_enums: list<string>, facade_funcs: list<string>, deviating_callbacks: array<string, string>}'
        GeneratorContext: 'array{enums: array<string, array<string, int>>, types: list<string>, generatedTypes: list<string>, functions: array<string, ParsedFunction>, annotations: GeneratorAnnotations, docs: array<string, DocData>}'
    paths:
        - src
        - tools
        - tests

    stubFiles:
        - stubs/FFI.php

    # The FFI-dynamic noise (uiXxx() calls on the \FFI handle, struct field access
    # on \FFI\CData) and a few intentional retention-property / test-assertion
    # findings are captured in phpstan-baseline.neon, matched by file + message +
    # count so they survive formatter line shifts. Regenerate with:
    #   vendor/bin/phpstan analyse --generate-baseline phpstan-baseline.neon
