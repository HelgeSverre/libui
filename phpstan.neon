includes:
    - phpstan-baseline.neon

parameters:
    level: 6
    paths:
        - src
        - tools
        - tests

    # The FFI-dynamic noise (uiXxx() calls on the \FFI handle, struct field access
    # on \FFI\CData) and a few intentional retention-property / test-assertion
    # findings are captured in phpstan-baseline.neon, matched by file + message +
    # count so they survive formatter line shifts. Regenerate with:
    #   vendor/bin/phpstan analyse --generate-baseline phpstan-baseline.neon
